# MEXC Ghost Hunter - Environment Variables

# ==========================================
# SECURITY - REQUIRED FOR PRODUCTION
# ==========================================
# Set a strong, unique password (minimum 8 characters)
# Example: openssl rand -base64 24
ADMIN_PASSWORD=your_very_secure_password_here_change_me

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=8080
RUST_LOG=info
RUST_BACKTRACE=1
DATA_DIR=/data

# ==========================================
# TRADING ENGINE PARAMETERS
# ==========================================
# Minimum profit threshold to report (as decimal: 0.15% = 0.0015)
MIN_PROFIT_THRESHOLD=0.0015

# Target volume for weighted average fill simulation (USD)
TARGET_VOLUME_USD=1000.0

# Minimum 24h volume to include in whitelist (USD)
MIN_VOLUME_24H=500000.0

# ==========================================
# MEXC API (Optional - Add if using paper trading)
# ==========================================
# MEXC_API_KEY=your_api_key_here
# MEXC_API_SECRET=your_api_secret_here

# ==========================================
# PERSISTENCE
# ==========================================
# SQLite database location (inside /data volume)
DATABASE_URL=sqlite:///data/mexc.db
